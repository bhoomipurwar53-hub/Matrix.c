#include <stdio.h>

void inputMatrix(int matrix[10][10], int row, int col)
{
    int i, j;
    for(i = 0; i < row; i++)
    {
        for(j = 0; j < col; j++)
        {
            scanf("%d", &matrix[i][j]);
        }
    }
}

void displayMatrix(int matrix[10][10], int row, int col)
{
    int i, j;
    for(i = 0; i < row; i++)
    {
        for(j = 0; j < col; j++)
        {
            printf("%d ", matrix[i][j]);
        }
        printf("\n");
    }
}

void addMatrix(int A[10][10], int B[10][10], int row, int col)
{
    int C[10][10], i, j;

    for(i = 0; i < row; i++)
    {
        for(j = 0; j < col; j++)
        {
            C[i][j] = A[i][j] + B[i][j];
        }
    }

    printf("\nAddition Result:\n");
    displayMatrix(C, row, col);
}

void multiplyMatrix(int A[10][10], int B[10][10], int row, int col)
{
    int C[10][10], i, j, k;

    for(i = 0; i < row; i++)
    {
        for(j = 0; j < col; j++)
        {
            C[i][j] = 0;
            for(k = 0; k < col; k++)
            {
                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }

    printf("\nMultiplication Result:\n");
    displayMatrix(C, row, col);
}

void transposeMatrix(int A[10][10], int row, int col)
{
    int i, j;

    printf("\nTranspose Matrix:\n");
    for(i = 0; i < col; i++)
    {
        for(j = 0; j < row; j++)
        {
            printf("%d ", A[j][i]);
        }
        printf("\n");
    }
}

int main()
{
    int A[10][10], B[10][10];
    int row, col;

    printf("Enter rows and columns: ");
    scanf("%d %d", &row, &col);

    printf("Enter elements of Matrix A:\n");
    inputMatrix(A, row, col);

    printf("Enter elements of Matrix B:\n");
    inputMatrix(B, row, col);

    addMatrix(A, B, row, col);
    multiplyMatrix(A, B, row, col);
    transposeMatrix(A, row, col);

    return 0;
}
